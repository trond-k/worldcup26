{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "results.schema.json",
  "title": "World Cup 2026 Results (one file per matchday date)",
  "type": "object",
  "additionalProperties": false,
  "required": ["date", "matches"],
  "properties": {
    "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "matches": {
      "type": "array",
      "items": { "$ref": "#/definitions/match" }
    }
  },
  "definitions": {
    "match": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage", "home", "away", "home_score", "away_score", "status"],
      "properties": {
        "stage": { "type": "string", "enum": ["group", "round-of-32", "round-of-16", "quarter-final", "semi-final", "third-place", "final"] },
        "group": { "type": ["string", "null"], "pattern": "^[A-L]$" },
        "matchday": { "type": ["integer", "null"], "minimum": 1, "maximum": 3 },
        "home": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "away": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "home_score": { "type": ["integer", "null"], "minimum": 0 },
        "away_score": { "type": ["integer", "null"], "minimum": 0 },
        "status": { "type": "string", "enum": ["completed", "scheduled"] },
        "venue": { "type": ["string", "null"] },
        "note": { "type": ["string", "null"] }
      }
    }
  }
}
