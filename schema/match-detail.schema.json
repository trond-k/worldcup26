{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "match-detail.schema.json",
  "title": "World Cup 2026 Match Detail",
  "description": "Rich detail for a single completed match: goals, cards, lineups, substitutions and team stats. Stored at data/results/matches/<id>.json. All rich fields are optional/partial; include only what is corroborated by trustworthy sources.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "date", "home", "away", "home_score", "away_score"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "home": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "away": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "home_score": { "type": "integer", "minimum": 0 },
    "away_score": { "type": "integer", "minimum": 0 },
    "attendance": { "type": ["integer", "null"], "minimum": 0 },
    "referee": { "type": ["string", "null"] },
    "sources": { "type": "array", "items": { "type": "string" } },
    "goals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["team", "player", "minute", "type"],
        "properties": {
          "team": { "type": "string", "description": "slug of the team CREDITED with the goal (for own goals, the beneficiary)" },
          "player": { "type": "string" },
          "minute": { "type": ["string", "null"], "pattern": "^\\d{1,3}(\\+\\d{1,2})?$" },
          "type": { "type": "string", "enum": ["regular", "penalty", "own_goal"] },
          "assist": { "type": ["string", "null"] }
        }
      }
    },
    "cards": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["team", "player", "minute", "card"],
        "properties": {
          "team": { "type": "string" },
          "player": { "type": "string" },
          "minute": { "type": ["string", "null"], "pattern": "^\\d{1,3}(\\+\\d{1,2})?$" },
          "card": { "type": "string", "enum": ["yellow", "second-yellow", "red"] }
        }
      }
    },
    "substitutions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["team"],
        "properties": {
          "team": { "type": "string" },
          "off": { "type": ["string", "null"] },
          "on": { "type": ["string", "null"] },
          "minute": { "type": "string", "pattern": "^\\d{1,3}(\\+\\d{1,2})?$" }
        }
      }
    },
    "lineups": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "home": { "$ref": "#/definitions/lineup" },
        "away": { "$ref": "#/definitions/lineup" }
      }
    },
    "stats": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "home": { "$ref": "#/definitions/teamstats" },
        "away": { "$ref": "#/definitions/teamstats" }
      }
    }
  },
  "definitions": {
    "lineup": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "formation": { "type": ["string", "null"] },
        "manager": { "type": ["string", "null"] },
        "starting": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "position": { "type": ["string", "null"], "enum": ["GK", "DF", "MF", "FW", null] },
              "number": { "type": ["integer", "null"], "minimum": 1, "maximum": 99 }
            }
          }
        }
      }
    },
    "teamstats": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "possession": { "type": ["integer", "null"], "minimum": 0, "maximum": 100 },
        "shots": { "type": ["integer", "null"], "minimum": 0 },
        "shots_on_target": { "type": ["integer", "null"], "minimum": 0 },
        "corners": { "type": ["integer", "null"], "minimum": 0 },
        "fouls": { "type": ["integer", "null"], "minimum": 0 },
        "offsides": { "type": ["integer", "null"], "minimum": 0 },
        "yellow_cards": { "type": ["integer", "null"], "minimum": 0 },
        "red_cards": { "type": ["integer", "null"], "minimum": 0 },
        "saves": { "type": ["integer", "null"], "minimum": 0 },
        "passes": { "type": ["integer", "null"], "minimum": 0 },
        "pass_accuracy": { "type": ["integer", "null"], "minimum": 0, "maximum": 100 }
      }
    }
  }
}
